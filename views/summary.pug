html
  head
    title Stock Summary
    link(rel='stylesheet', href='/styles.css')
  body
    h1 Stock Summary

    h2 Overview
    p Total Products: #{totalProducts}
    p Total Stock Units: #{totalStock}
    p Total Stock Value: £#{totalValue}

    h2 Products by Category
    p Clothing: #{byCategory.clothing}
    p Electronics: #{byCategory.electronic}
    p Books: #{byCategory.book}

    h2 Low Stock Alert (under 30 units)
    if lowStock.length === 0
      p All products are sufficiently stocked.
    else
      table
        thead
          tr
            th ID
            th Name
            th Price
            th Quantity
            th Type
        tbody
          each product in lowStock
            tr
              td= product.id
              td= product.name
              td= product.price
              td= product.quantity
              td= product.type

    h2 Full Stock List
    table
      thead
        tr
          th ID
          th Name
          th Price
          th Quantity
          th Type
          th Stock Value
      tbody
        each product in products
          tr
            td= product.id
            td= product.name
            td= product.price
            td= product.quantity
            td= product.type
            td= '£' + (product.price * product.quantity).toFixed(2)

    a(href="/") Back to Inventory